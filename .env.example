# Secrets are managed via Doppler. Account is at the 10-project cap, so this
# pipeline REUSES the youtube-title-autoresearch project (config=dev) as its
# secrets home. This file only documents which keys the pipeline expects.
#
#   doppler run --project youtube-title-autoresearch --config dev -- python pipeline.py --now

GROQ_API_KEY=                 # Groq free tier (scripts + metadata) — ALREADY SET (copied from philosopher-pipeline)

# YouTube Data API v3 OAuth (generate the refresh token once, locally)
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=

# Safety: set to 1 to render without uploading (no quota burn)
YT_DRY_RUN=1

# Optional. Wikimedia's User-Agent policy 429-blocks generic agents; the code
# defaults the contact to the public repo URL (works as-is). Override here with
# an email if Wikimedia ever throttles, e.g. WIKIMEDIA_CONTACT=you@example.com
WIKIMEDIA_CONTACT=

# Optional. Pexels stock b-roll for beats with no Commons hit (free key from
# https://www.pexels.com/api/). Accepts a comma-separated list; requests
# round-robin across keys. Unset = the old gradient-card fallback, no failure.
# NOTE: live_monitor.py (goal-news) DISABLES this layer in-process so goal
# shorts are always stills-only (legal: never broadcast/video footage).
PEXELS_API_KEY=

# live_monitor.py (first-to-post GOAL-NEWS detector, DRY-RUN by design).
# Free football-data.org key: https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=
# Safety gate for a minor's account: auto-publish to YouTube is OFF unless this
# is exactly 1 AND real YT creds exist. Default/absent = render + stage only,
# nothing is ever posted.
LIVE_MONITOR_AUTOPOST=0
